7.	Prefix sum
--> Idea:                   Store sum till each index
--> arr = [1,2,3,4]                             prefix = [1,3,6,10]
public class PrefixSumOfArray
{
    public static void main(String[] args) 
    {
        int[] arr = {1,2,3,4};
        int[] prefix = new int[arr.length];
        prefix[0] = arr[0];
        for (int i = 1; i < arr.length; i++) 
        {
            prefix[i] = prefix[i - 1] + arr[i];
        }
        for (int i = 0; i < prefix.length; i++) 
        {
            System.out.print(prefix[i] + " ");
        }   }   }

8.	Sliding window
--> SLIDING WINDOW = “MOVING WINDOW”

--> Imagine:         You have a window of size k and You slide it over array. 

--> Example:            arr = [2, 1, 5, 1, 3, 2],     k = 3      Window moves like this:
[2, 1, 5] → sum = 8
   [1, 5, 1] → sum = 7
      [5, 1, 3] → sum = 9
         [1, 3, 2] → sum = 6

--> MAIN IDEA (REMEMBER FOREVER)
•	Just      REMOVE left  +  ADD right

--> SUPER FORMULA:    windowSum = windowSum - arr[i-1] + arr[i+k-1]

--> MEMORY TRICK:          START → first k sum then MOVE → -left +right and then CHECK → max.

public class SlidingSumOfSubArray
{
    public static void main(String[] args) 
    {
        int[] arr = {10,50,60,70,20};
        int k = 3;
        int Sum = 0;
        for(int i = 0; i < k; i++)
        {
            Sum += arr[i];
        }
        int maxSum = Sum;
        for (int i = 1; i <= arr.length - k; i++) 
        {
            Sum = Sum - arr[i - 1] + arr[i + k - 1];
            if (Sum > maxSum) 
            {
                maxSum = Sum;
            }   }
        System.out.println(maxSum);
    }    }

9.	Second Largest Element
--> Formula:     keep max and secondMax

--> Every number ask am I biggest and if yes then it becomes new max and old max becomes second. If no then ask am I better than second if it is yes then update second.

public class SecondLargestArray
{
    public static void main(String[] args)
    {
        int[] arr = {10,20,30,70,40,80};
        int max, SecondMax;
        if(arr[0] > arr[1])
        {
            max = arr[0];
            SecondMax = arr[1];
        }
        else
        {
            max = arr[1];
            SecondMax = arr[0];
        }
        for(int i = 2; i < arr.length; i++)
        {
            if(arr[i] > max)
            {
                SecondMax = max;
                max = arr[i];
            }
            else if(arr[i] > SecondMax && arr[i] != max)
            {
                SecondMax = arr[i];
            }    }
        System.out.println(SecondMax);
    }   }


10.	Move Zeros to End
--> Formula:      place non-zero first
--> Move all 0 to end and Keep non-zero in front.
--> arr[i] != 0 → swap with j → j++
public class MoveZeroEndArray
{
    public static void main(String[] args)
    {
        int[] arr = {10, 0, 20, 0, 30, 70};
        int j = 0;
        for(int i = 0; i < arr.length; i++)
        {
            if(arr[i] != 0)
            {
                int temp = arr[i];
                arr[i] = arr[j];
                arr[j] = temp;
                j++;
            }   }
        for(int i = 0; i < arr.length; i++)
        {
            System.out.println(arr[i] + " ");
        }  }  }

11.	Check Sorted Array
--> Formula:                arr[i] <= arr[i+1]
--> Loop → compare neighbours → break if wrong
public class SortedArray
{
    public static void main(String[] args)
    {
        int[] arr = {10,20,30,40,60,50};
        boolean IsSorted = true;
        for(int i = 0; i < arr.length - 1; i++)
        {
            if(arr[i] >= arr[i+1])
            {
                IsSorted = false;
                break;
            }    }
        System.out.println(IsSorted);
    }    }

12.	Remove Duplicates (Sorted Array)
--> Formula:      use two pointers
public class RemoveDuplicateArray
{
    public static void main(String[] args)
    {
        int[] arr = {10,20,20,30,30,30,40,40,40};
        int j = 0;
        for(int i = 1; i < arr.length; i++)
        {
